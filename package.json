{
  "name": "nmfa",
  "version": "0.1.0",
  "description": "No Money For AI - Standalone IDE with local LLM integration",
  "main": "dist/main.js",
  "scripts": {
    "start": "npm run build && electron dist/main.js",
    "dev": "tsc && npm start",
    "build": "tsc && cp src/index.html dist/",
    "lint": "eslint src/**/*.ts",
    "format": "clang-format -i src/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "smoke-test": "npm run build && npm run lint && npm test",
    "audit": "npm audit"
  },
  "dependencies": {
    "electron": "^25.0.0",
    "monaco-editor": "^0.44.0",
    "@types/node": "^20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "clang-format": "^1.8.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "NMFA Team",
  "license": "MIT"
}
